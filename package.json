{
  "name": "colombo",
  "version": "0.1.0",
  "description": "Answer any operational question in Slack in minutes with a read-only Codex agent connected to your MCP tools.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "improvement:review": "tsx src/improvement.ts review",
    "improvement:apply": "tsx src/improvement.ts apply"
  },
  "dependencies": {
    "@slack/bolt": "^4.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
