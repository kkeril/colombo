# Copy to /etc/colombo.env on the VPS and fill values there.
# Do not commit real token values.

slack_bot_token=xoxb-your-bot-token
slack_app_token=xapp-your-app-level-token
slack_allowed_user_ids=U012ABCDEF,U045GHIJKL

# Codex executable and workspace paths.
codex_bin=codex
codex_workdir=/opt/colombo
colombo_dir=/opt/colombo
agent_instructions_file=AGENTS.md
state_dir=/var/lib/colombo

# Comma-separated MCP server names that Codex may use during investigations.
# The server definitions and credentials live in the VPS Codex config, not in this file.
codex_mcp_server_names=grafana,logs,github,stripe,posthog,database,docs
codex_disabled_mcp_server_names=

max_concurrent_jobs=1
max_queue_size=5
job_timeout_ms=900000
slack_reaction=eyes
slack_thread_limit=20
final_response_max_chars=3500
progress_updates_enabled=true
progress_min_interval_ms=60000
progress_heartbeat_ms=120000
feedback_enabled=true
feedback_clarification_wait_ms=86400000

# Owner-approved self-improvement CLI options.
colombo_improvement_lookback_days=1
colombo_improvement_max_jobs=40
colombo_improvement_auto_commit=false
colombo_improvement_auto_push=false
